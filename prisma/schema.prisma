generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  dishes    Dish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String
  price       String?
  imageUrl    String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  badge       String?
  allergens   String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuDocument {
  id         String   @id @default(cuid())
  title      String
  fileUrl    String
  isActive   Boolean  @default(true)
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([uploadedAt])
}

model GalleryImage {
  id         String   @id @default(cuid())
  title      String
  imageUrl   String
  alt        String
  type       String
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EventService {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   @default("événement privé")
  capacity    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id        String   @id @default(cuid())
  name      String
  phone     String
  date      String
  time      String
  guests    Int
  message   String?
  status    String   @default("nouvelle")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(cuid())
  author     String
  quote      String
  context    String?
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SeoPage {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String
  description String
  keywords    String?
  ogImage     String?
  slug        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandAsset {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  value     String
  type      String   @default("text")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("Admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LoyaltyCustomerStatus {
  ACTIVE
  BLOCKED
}

enum LoyaltyRewardType {
  DISCOUNT_25
  DISCOUNT_50
}

enum LoyaltyRewardStatus {
  AVAILABLE
  USED
  EXPIRED
  CANCELLED
}

enum LoyaltyTransactionType {
  CARD_CREATED
  STAMP_ADDED
  STAMP_REMOVED
  REWARD_UNLOCKED
  REWARD_USED
  RESET
  BLOCKED
  UNBLOCKED
  MANUAL_ADJUSTMENT
}

model LoyaltyCustomer {
  id                String                @id @default(cuid())
  firstName         String
  lastName          String?
  phone             String                @unique
  email             String?
  publicToken       String                @unique
  stampCount        Int                   @default(0)
  lifetimePurchases Int                   @default(0)
  cycleNumber       Int                   @default(1)
  status            LoyaltyCustomerStatus @default(ACTIVE)
  walletProvider    String?
  walletPassId      String?
  walletLastSyncAt  DateTime?
  rewards           LoyaltyReward[]
  transactions      LoyaltyTransaction[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LoyaltyReward {
  id           String               @id @default(cuid())
  customerId   String
  customer     LoyaltyCustomer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cycleNumber  Int
  type         LoyaltyRewardType
  status       LoyaltyRewardStatus  @default(AVAILABLE)
  unlockedAt   DateTime             @default(now())
  usedAt       DateTime?
  transactions LoyaltyTransaction[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([customerId, cycleNumber, type])
  @@index([status])
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  customerId  String
  customer    LoyaltyCustomer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cycleNumber Int
  type        LoyaltyTransactionType
  stampDelta  Int?
  rewardId    String?
  reward      LoyaltyReward?         @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  adminId     String?
  note        String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime               @default(now())

  @@index([customerId, createdAt])
  @@index([type])
  @@index([adminId])
}
